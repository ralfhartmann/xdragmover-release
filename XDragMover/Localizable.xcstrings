    "Middle-clicking an app's Dock icon opens a new window/instance of it.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Mittelklick auf das Dock-Symbol einer App öffnet ein neues Fenster/eine neue Instanz davon."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Щелчок средней кнопкой мыши по значку приложения в Dock открывает его новое окно/копию."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un clic central sur l'icône du Dock d'une application ouvre une nouvelle fenêtre/instance de celle-ci."
          }
        }
      }
    },
