          }
        }
      }
    },
    "Window move, resize, and focus-follows-mouse will stop working until you relaunch it.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fensterverschiebung, -größenänderung und „Fokus folgt Maus“ funktionieren erst nach einem Neustart wieder."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перемещение окон, изменение размера и функция «Фокус следует за мышью» перестанут работать до повторного запуска приложения."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le déplacement de fenêtre, le redimensionnement et le focus qui suit la souris cesseront de fonctionner jusqu'à ce que vous la relanciez."
          }
        }
      }
    },
