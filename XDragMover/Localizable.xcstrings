{
  "sourceLanguage": "en",
  "strings": {
    "%lldms — how long the cursor must stay still before the window under it receives input": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%lldms – so lange muss der Zeiger stillstehen, bevor das Fenster darunter Eingaben erhält"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld мс — как долго курсор должен оставаться неподвижным, прежде чем окно под ним начнёт получать ввод"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld ms – durée pendant laquelle le curseur doit rester immobile avant que la fenêtre en dessous ne reçoive les entrées"
          }
        }
      }
    },
    "1s": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "1 s"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "1 с"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "1 s"
          }
        }
      }
    },
    "50ms": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "50 ms"
          }
        },
