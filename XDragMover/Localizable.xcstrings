            "state": "translated",
            "value": "Обновить формат настроек?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mettre à jour le format des réglages ?"
          }
        }
      }
    },
    "Use Defaults Instead": {
      "localizations": {
