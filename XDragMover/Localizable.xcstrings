    "Apps in this list can never be moved or resized by XDragMover.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Apps in dieser Liste können von XDragMover niemals verschoben oder in der Größe verändert werden."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Приложения из этого списка никогда не будут перемещены или изменены в размере с помощью XDragMover."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les applications de cette liste ne peuvent jamais être déplacées ni redimensionnées par XDragMover."
          }
        }
      }
    },
