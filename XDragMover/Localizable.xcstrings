    "Checks github.com for a newer release 5 minutes after launch, then once a day. Nothing else is sent.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Prüft 5 Minuten nach dem Start und danach einmal täglich bei github.com auf eine neuere Version. Es werden keine weiteren Daten gesendet."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проверяет github.com на наличие новой версии через 5 минут после запуска, а затем раз в день. Больше ничего не отправляется."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vérifie sur github.com la présence d'une nouvelle version 5 minutes après le lancement, puis une fois par jour. Rien d'autre n'est envoyé."
          }
        }
      }
    },
