          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Afficher la console de débogage"
          }
        }
      }
    },
    "Start at Login": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bei Anmeldung starten"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Запускать при входе в систему"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Démarrer à l'ouverture de session"
          }
        }
      }
    },
    "This relies on an undocumented macOS mechanism that Apple could change or remove without notice, and some apps (e.g. Firefox) don't fully respect it — it may behave unreliably.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies basiert auf einem undokumentierten macOS-Mechanismus, den Apple jederzeit ohne Vorankündigung ändern oder entfernen könnte, und manche Apps (z. B. Firefox) berücksichtigen ihn nicht vollständig – das Verhalten kann daher unzuverlässig sein."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это основано на недокументированном механизме macOS, который Apple может изменить или убрать без предупреждения, а некоторые приложения (например, Firefox) не полностью его учитывают — поведение может быть нестабильным."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ceci repose sur un mécanisme macOS non documenté qu'Apple pourrait modifier ou supprimer sans préavis, et certaines applications (par ex. Firefox) ne le respectent pas entièrement — le comportement peut donc être imprévisible."
          }
        }
      }
    },
    "Update Settings Format?": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einstellungsformat aktualisieren?"
          }
